rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función helper: obtener el rol del usuario autenticado
    function userBar() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.bar;
    }
    function isAuth() {
      return request.auth != null;
    }

    // /config — solo lectura para cualquier autenticado, nadie escribe desde cliente
    match /config/{doc} {
      allow read:  if isAuth();
      allow write: if false;
    }

    // /usuarios — cada usuario solo puede leer su propio perfil
    match /usuarios/{uid} {
      allow read:  if isAuth() && request.auth.uid == uid;
      allow write: if false;
    }

    // /estado — lectura para todos, escritura solo al propio bar
    match /estado/{barId} {
      allow read:   if isAuth();
      allow update: if isAuth() && (userBar() == barId || userBar() == 'admin');
      allow create, delete: if false;
    }

    // /ventas — cualquier autenticado puede crear, nadie puede editar ni borrar
    match /ventas/{ventaId} {
      allow read:   if isAuth();
      allow create: if isAuth()
        && request.resource.data.bar      is string
        && request.resource.data.producto  is string
        && request.resource.data.cantidad  is number
        && request.resource.data.total     is number
        && request.resource.data.usuario_uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
